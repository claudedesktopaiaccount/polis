# Cloudflare D1 — required for Drizzle migrations and local dev
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=3988aa54-17b6-4286-b815-eac8ff6ab636
CLOUDFLARE_D1_TOKEN=

# Sentry error monitoring (optional — set via `wrangler secret put SENTRY_DSN`)
SENTRY_DSN=

# Canonical site URL — used in sitemap, robots.txt, OG metadata
NEXT_PUBLIC_SITE_URL=https://progresivne.sk

# Umami Cloud analytics — website ID from umami.is dashboard
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Admin panel
ADMIN_SECRET=change-me-in-production

# Email — Resend (set via `wrangler secret put RESEND_API_KEY` in production)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Newsletter cron authentication (set via `wrangler secret put CRON_SECRET` in production)
CRON_SECRET=your-random-secret-here
