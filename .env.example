# Cloudflare D1 — required for Drizzle migrations and local dev
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=your-d1-database-id
CLOUDFLARE_D1_TOKEN=

# Sentry error monitoring (optional — set via `wrangler secret put SENTRY_DSN`)
SENTRY_DSN=

# Canonical site URL — used in sitemap, robots.txt, OG metadata
NEXT_PUBLIC_SITE_URL=https://progresivne.sk

# Umami Cloud analytics — website ID from umami.is dashboard
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Admin panel
ADMIN_SECRET=change-me-in-production

# Resend — email sending for newsletter
RESEND_API_KEY=re_xxxxxxxxxxxx

# Cron secret — authenticates scheduled triggers (set via: wrangler secret put CRON_SECRET)
# Generate with: openssl rand -hex 32
CRON_SECRET=<generate with: openssl rand -hex 32>

# Stripe — API access billing
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxx

# Anthropic — AI narrative generation for /predikcia
# Set via: npx wrangler secret put ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=your_anthropic_api_key_here
