{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "polis",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-15",
  "compatibility_flags": ["nodejs_compat_v2"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // ADMIN_SECRET must be set via: npx wrangler secret put ADMIN_SECRET
  // CRON_SECRET must be set via: npx wrangler secret put CRON_SECRET
  "vars": {
    "NEXT_PUBLIC_UMAMI_WEBSITE_ID": "c08dd305-ebb3-4041-9c02-fcd92bef838b"
  },
  "triggers": {
    "crons": [
      "0 9 * * 1",
      "0 * * * *"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "progresivny-tracker",
      "database_id": "3988aa54-17b6-4286-b815-eac8ff6ab636",
      "migrations_dir": "drizzle"
    }
  ]
}
