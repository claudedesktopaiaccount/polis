{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "volimto",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-15",
  "compatibility_flags": ["nodejs_compat_v2"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // ADMIN_SECRET must be set via: npx wrangler secret put ADMIN_SECRET
  // CRON_SECRET must be set via: npx wrangler secret put CRON_SECRET
  // ANTHROPIC_API_KEY must be set via: npx wrangler secret put ANTHROPIC_API_KEY
  // RESEND_API_KEY must be set via: npx wrangler secret put RESEND_API_KEY
  "vars": {
    "NEXT_PUBLIC_UMAMI_WEBSITE_ID": "c08dd305-ebb3-4041-9c02-fcd92bef838b"
  },
  "triggers": {
    "crons": [
      "0 9 * * 1",
      "0 * * * *"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "volimto",
      "database_id": "e8f96076-c25f-42a6-a98e-7d927136783e",
      "migrations_dir": "drizzle"
    }
  ]
}
